# amneziawg-web configuration
# Copy this file to .env or to /etc/amneziawg-web/env.conf and adjust values.
# Never commit a file that contains real secrets.

# ── Server ──────────────────────────────────────────────────────────────────

# TCP address the HTTP server will listen on.
# Use 127.0.0.1:8080 in production (reverse-proxy in front).
AWG_WEB_LISTEN=0.0.0.0:8080

# Path to the SQLite database file.
# Use an absolute path in production, e.g. /var/lib/amneziawg-web/awg-web.db
AWG_WEB_DB=awg-web.db

# ── AWG integration ──────────────────────────────────────────────────────────

# Directory where AWG client config files (*.conf) are stored.
AWG_CONFIG_DIR=/etc/amneziawg/clients

# How often to poll `awg show all dump`, in seconds.
AWG_POLL_INTERVAL=30

# ── Logging ──────────────────────────────────────────────────────────────────

# Log verbosity. Valid values: error, warn, info, debug, trace.
RUST_LOG=amneziawg_web=info

# ── Authentication ───────────────────────────────────────────────────────────

# Set to true in production. When false, all requests are accepted without
# credentials — do NOT expose the panel on a public network in this state.
AUTH_ENABLED=false

# Admin username shown in the login form.
AUTH_USERNAME=admin

# Argon2id PHC hash of the admin password.
# Generate with:
#   python3 -c "import argon2; print(argon2.PasswordHasher().hash('yourpassword'))"
# The result looks like: $argon2id$v=19$m=65536,t=3,p=4$<salt>$<hash>
# Required when AUTH_ENABLED=true.
AUTH_PASSWORD_HASH=

# Optional static bearer token for headless API access.
# Accepted via: Authorization: Bearer <token>
# Generate with: openssl rand -hex 32
# Leave blank to disable bearer-token auth.
AUTH_API_TOKEN=

# Set to true when the panel is served over HTTPS.
# Adds the Secure flag to the session cookie.
AUTH_SECURE_COOKIE=false

# Session lifetime in seconds. Default is 86400 (24 hours).
AUTH_SESSION_TTL_SECS=86400
