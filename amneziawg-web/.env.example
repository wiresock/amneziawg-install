# amneziawg-web configuration
# Copy this file to .env and adjust values for your environment.

# TCP address the HTTP server will listen on.
AWG_WEB_LISTEN=0.0.0.0:8080

# Path to the SQLite database file.
AWG_WEB_DB=awg-web.db

# Directory where AWG client configs are stored.
AWG_CONFIG_DIR=/etc/amneziawg/clients

# Polling interval in seconds (how often to call `awg show`).
AWG_POLL_INTERVAL=30

# Log level filter (error|warn|info|debug|trace).
RUST_LOG=amneziawg_web=info,tower_http=debug
